{
  "request": {
    "method": "POST",
    "urlPath": "/token",
    "headers": {
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "contains": "grant_type=authorization_code"
      },
      {
        "contains": "code=harigata-auth-code"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "access_token": "harigata-access-token",
      "id_token": "harigata-id-token",
      "token_type": "Bearer",
      "expires_in": 3600,
      "scope": "openid profile email"
    }
  }
}
