{
  "request": {
    "method": "GET",
    "urlPath": "/.well-known/openid-configuration"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "issuer": "{{request.baseUrl}}",
      "authorization_endpoint": "{{request.baseUrl}}/authorize",
      "token_endpoint": "{{request.baseUrl}}/token",
      "userinfo_endpoint": "{{request.baseUrl}}/userinfo",
      "jwks_uri": "{{request.baseUrl}}/jwks",
      "response_types_supported": [
        "code"
      ],
      "subject_types_supported": [
        "public"
      ],
      "id_token_signing_alg_values_supported": [
        "RS256"
      ],
      "token_endpoint_auth_methods_supported": [
        "client_secret_post"
      ],
      "scopes_supported": [
        "openid",
        "profile",
        "email"
      ]
    },
    "transformers": [
      "response-template"
    ]
  }
}
